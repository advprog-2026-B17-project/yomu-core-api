JWT_SECRET=<same-value-as-gateway>
GATEWAY_SHARED_SECRET=<same-value-as-gateway-and-gamification>

DATABASE_JDBC_URL=jdbc:postgresql://<core-neon-host>/<core-neon-database>?sslmode=require&channel_binding=require&currentSchema=auth,quiz,gamification
DB_USER=<core-neon-user>
DB_PASSWORD=<core-neon-password>

RABBITMQ_HOST=<cloudamqp-host>
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=<cloudamqp-user>
RABBITMQ_PASSWORD=<cloudamqp-password>
RABBITMQ_VHOST=<cloudamqp-vhost>

GOOGLE_CLIENT_ID=<google-client-id>
